<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.onlinestore.mapper.PointRuleMapper">
    <resultMap id="pointRuleResultMap" type="com.example.onlinestore.entity.PointRuleEntity">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="description" property="description"/>
        <result column="points" property="points"/>
        <result column="status" property="status"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
    </resultMap>

    <sql id="pointRuleColumns">
        id, name, description, points, status, created_at, updated_at
    </sql>

    <select id="findById" resultMap="pointRuleResultMap">
        SELECT
        <include refid="pointRuleColumns"/>
        FROM point_rule
        WHERE id = #{id}
    </select>

    <select id="findAllActive" resultMap="pointRuleResultMap">
        SELECT
        <include refid="pointRuleColumns"/>
        FROM point_rule
        WHERE status = 1
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO point_rule (
            name, description, points, status, created_at, updated_at
        ) VALUES (
            #{name}, #{description}, #{points}, #{status}, NOW(), NOW()
        )
    </insert>

    <update id="update">
        UPDATE point_rule
        SET name = #{name},
            description = #{description},
            points = #{points},
            status = #{status},
            updated_at = NOW()
        WHERE id = #{id}
    </update>

    <update id="updateStatus">
        UPDATE point_rule
        SET status = #{status},
            updated_at = NOW()
        WHERE id = #{id}
    </update>
</mapper> 