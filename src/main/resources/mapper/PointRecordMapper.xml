<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.onlinestore.mapper.PointRecordMapper">
    <resultMap id="pointRecordResultMap" type="com.example.onlinestore.entity.PointRecordEntity">
        <id column="id" property="id"/>
        <result column="member_id" property="memberId"/>
        <result column="order_no" property="orderNo"/>
        <result column="points" property="points"/>
        <result column="type" property="type"/>
        <result column="description" property="description"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
    </resultMap>

    <sql id="pointRecordColumns">
        `id`, `member_id`, `order_no`, `points`, `type`, `description`, `created_at`, `updated_at`
    </sql>

    <select id="findById" resultMap="pointRecordResultMap">
        SELECT
        <include refid="pointRecordColumns"/>
        FROM `point_record`
        WHERE id = #{id}
    </select>

    <select id="findByMemberId" resultMap="pointRecordResultMap">
        SELECT
        <include refid="pointRecordColumns"/>
        FROM `point_record`
        WHERE `member_id` = #{memberId}
        ORDER BY `created_at` DESC
    </select>

    <select id="findByOrderNo" resultMap="pointRecordResultMap">
        SELECT
        <include refid="pointRecordColumns"/>
        FROM `point_record`
        WHERE `order_no` = #{orderNo}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO `point_record` (
            `member_id`, `order_no`, `points`, `type`, `description`, `created_at`, `updated_at`
        ) VALUES (
            #{memberId}, #{orderId}, #{points}, #{type}, #{description}, NOW(), NOW()
        )
    </insert>

    <select id="getMemberPointBalance" resultType="java.math.BigDecimal">
        SELECT COALESCE(SUM(
            CASE 
                WHEN `type` = 1 THEN `points`
                WHEN `type` = 2 THEN -`points`
                ELSE 0
            END
        ), 0)
        FROM `point_record`
        WHERE `member_id` = #{memberId}
    </select>
</mapper> 